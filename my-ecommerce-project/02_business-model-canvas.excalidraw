      "seed": 1114886348,
      "version": 919,
      "versionNonce": 1355349200,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783697907694,
      "link": null,
      "locked": false,
      "text": "For players:\n- Easily find a group—no need to\nworry about loneliness or plans\nfalling through.\n- Reduced anxiety for new players\n(thanks to \"Open\" group options).\n\nFor venues:\n- Minimize \"no-shows\" (bookings that\nget abandoned) with a deposit\nsystem.\n- Manage tables systematically via a\ndedicated dashboard.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For players:\n- Easily find a group—no need to worry about loneliness or plans falling through.\n- Reduced anxiety for new players (thanks to \"Open\" group options).\n\nFor venues:\n- Minimize \"no-shows\" (bookings that get abandoned) with a deposit system.\n- Manage tables systematically via a dedicated dashboard.",
      "autoResize": false,
      "lineHeight": 1.35
    },
