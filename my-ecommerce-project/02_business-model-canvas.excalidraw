    {
      "id": "OQJh_OnFuap3RRbGknwlg",
      "type": "text",
      "x": 780.5812990529498,
      "y": 150.72682726902536,
      "width": 273.89446483894056,
      "height": 280.8,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
