cafes {
  _id: ObjectId,
  owner_id: ObjectId, // ref users
  name: string,
  description: string,
  address: string,
  location: {
    lat: number,
    lng: number
  },
  contact: {
    phone: string,
    facebook: string,
    line: string
  },
  opening_hours: [
    {
      day: string,
      open: string,
      close: string
    }
  ],
  tables: [
    {
      table_no: string,
      capacity: number,
      status: string
    }
  ],
  created_at: Timestamp
}