const cafeTableSchema = new mongoose.Schema({
  cafe_id: { type: mongoose.Schema.Types.ObjectId, ref: 'Cafe', required: true },
  table_number: { type: String, required: true },
  capacity: { type: Number, required: true },
  status: { 
    type: String, 
    enum: ['available', 'occupied', 'out_of_service'], 
    default: 'available' 
  }
});

// ทำ Index ร่วมกันเพื่อให้ table_number ซ้ำกันไม่ได้ในคาเฟ่เดียวกัน
cafeTableSchema.index({ cafe_id: 1, table_number: 1 }, { unique: true });

module.exports = mongoose.model('CafeTable', cafeTableSchema);